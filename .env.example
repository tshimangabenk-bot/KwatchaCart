# ---------------------------------------------------------------------------
# KwatchaCart backend configuration
# Copy this file to `server/.env` (or set these in your environment) and fill
# in the values. Every variable has a sensible dev default, so the app runs
# out of the box with mock providers when nothing is configured.
# ---------------------------------------------------------------------------

# HTTP server
PORT=4000
# Public base URL of the backend, used to build catalog links sent over WhatsApp.
PUBLIC_BASE_URL=http://localhost:4000
# Public base URL of the customer web view (the tiny catalog SPA).
WEB_BASE_URL=http://localhost:5173

# Storage: path to the SQLite database file (created automatically).
DATABASE_PATH=./data/kwatchacart.sqlite

# ---------------------------------------------------------------------------
# WhatsApp Cloud API (Meta). Leave WHATSAPP_TOKEN empty to run in "console"
# mode where outbound messages are logged & stored instead of sent.
# ---------------------------------------------------------------------------
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Token you invent; must match the value you configure in the Meta webhook UI.
WHATSAPP_VERIFY_TOKEN=kwatchacart-verify
WHATSAPP_API_VERSION=v21.0

# ---------------------------------------------------------------------------
# Mobile Money payments.
# PAYMENT_PROVIDER = mock | mtn | pawapay
#   mock    -> in-process simulator (auto-confirms after a short delay)
#   mtn     -> MTN MoMo Collections sandbox (requires the keys below)
#   pawapay -> PawaPay aggregator (requires PAWAPAY_TOKEN)
# ---------------------------------------------------------------------------
PAYMENT_PROVIDER=mock
# Seconds the mock provider waits before firing its success webhook.
MOCK_PAYMENT_DELAY_SECONDS=5
# Shared secret used to authenticate inbound payment webhooks.
PAYMENT_WEBHOOK_SECRET=change-me-payment-secret

# MTN MoMo Collections (sandbox: https://momodeveloper.mtn.com)
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_API_USER=
MTN_MOMO_API_KEY=
MTN_MOMO_TARGET_ENVIRONMENT=sandbox

# PawaPay (https://docs.pawapay.io)
PAWAPAY_BASE_URL=https://api.sandbox.pawapay.io
PAWAPAY_TOKEN=
