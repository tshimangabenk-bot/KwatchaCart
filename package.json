{
  "name": "kwatchacart",
  "version": "0.1.0",
  "private": true,
  "description": "Zero-friction WhatsApp-first micro-ecommerce with Mobile Money payments for Zambian market vendors.",
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c green,cyan \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "npm run dev --workspace server",
    "dev:web": "npm run dev --workspace web",
    "build": "npm run build --workspace server && npm run build --workspace web",
    "test": "npm run test --workspace server",
    "start": "npm run start --workspace server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
